<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    tools:context=".LoginActivity">

    <View
        android:id="@+id/headerDecor"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iconPaw"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/vete_dog"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_avatar_circle"
        android:clipToOutline="true"
        android:contentDescription="Logo"
        app:layout_constraintTop_toTopOf="@id/headerDecor"
        app:layout_constraintBottom_toBottomOf="@id/headerDecor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/iconPaw"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/formCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerDecor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/loginUserOrMail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="@string/txt_user"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textSize="15sp"
            android:textColor="@color/violeta_oscuro"
            android:textColorHint="@color/colorHint"
            android:autofillHints=""
            android:ems="10" />

        <Space android:layout_width="match_parent" android:layout_height="14dp" />

        <EditText
            android:id="@+id/loginPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="@string/txt_pass"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textSize="15sp"
            android:textColor="@color/violeta_oscuro"
            android:textColorHint="@color/colorHint"
            android:autofillHints=""
            android:ems="10" />

        <Space android:layout_width="match_parent" android:layout_height="10dp" />

        <CheckBox
            android:id="@+id/checkBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkbox_remember_me"
            android:textColor="@color/violeta"
            android:textSize="14sp"
            android:buttonTint="@color/violeta" />

        <Space android:layout_width="match_parent" android:layout_height="18dp" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_login"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <Button
        android:id="@+id/exitButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/btn_exit"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:background="@null"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>